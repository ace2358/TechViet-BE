{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-techviet-api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/techviet_be/techviet_be.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-techviet-api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/techviet_be/techviet_be.csproj"
      ],
      "group": "none",
      "problemMatcher": "$msCompile"
    }
  ]
}